{
  "name": "something",
  "productName": "App",
  "version": "1.4.0",
  "description": "this is just an app.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.swanky.todo",
    "productName": "Sw app",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "sw app"
    },
    "files": [
      "**/*",
      "!dist"
    ],
    "publish": {
      "provider": "github",
      "owner": "joshua-co29",
      "repo": "sw-app"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0"
  }
}